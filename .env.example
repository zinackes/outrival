# PostgreSQL — Neon (EU). Use the pooled connection string (-pooler host) with
# ?sslmode=require — the workers are ephemeral, so go through Neon's pooler.
DATABASE_URL=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=outrival-snapshots

# Better Auth
BETTER_AUTH_SECRET=        # 32+ chars random string
BETTER_AUTH_URL=           # https://api.outrival.io
# Registrable domain shared by web + api so the session cookie is readable on
# BOTH outrival.io and api.outrival.io (cross-subdomain). REQUIRED in prod when
# web and api are on different subdomains — without it the dashboard's RSC
# get-session runs cookie-less and bounces to /auth. Leave EMPTY in dev (the
# localhost cookie works host-only). See docs/deployment.md.
AUTH_COOKIE_DOMAIN=        # prod: outrival.io   ·   dev: (empty)

# Auth — Google OAuth (patch-19). Create at https://console.cloud.google.com →
# Credentials → OAuth Client ID (Web). Authorized redirect URI = BETTER_AUTH_URL +
# /api/auth/callback/google → dev: http://localhost:3001/api/auth/callback/google ,
# prod: https://api.outrival.io/api/auth/callback/google . (Better Auth derives the
# callback from BETTER_AUTH_URL — no GOOGLE_REDIRECT_URI env needed.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth — Cloudflare Turnstile (patch-19). Create a Managed widget at
# https://dash.cloudflare.com → Turnstile. Site key is public, secret stays server-side.
# Empty in dev → backend verification is bypassed (logged warning).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Auth — rate limiting (patch-19, Upstash). Empty Upstash creds → limiter is a no-op.
AUTH_RATE_LIMIT_EMAIL=3        # max attempts per email per window
AUTH_RATE_LIMIT_IP=10          # max attempts per IP per window
AUTH_RATE_LIMIT_WINDOW_MIN=15  # window length in minutes

# Trigger.dev
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# Scraping cascade (patch-20) — Patchright + ProxyScrape + Camoufox.
# ScrapingBee & Webshare removed. All proxy vars optional: a missing tier falls
# back to the direct IP for that level (best-effort), so dev works without proxies.
# ProxyScrape DATACENTER (L2 — primary paid level, flat monthly, unlimited BW).
PROXYSCRAPE_DC_ENDPOINT=                # host:port (e.g. dc.proxyscrape.com:PORT)
PROXYSCRAPE_DC_USERNAME=
PROXYSCRAPE_DC_PASSWORD=
# ProxyScrape RESIDENTIAL pay-per-GB (L3 + L4 fallback — NOT the Unlimited/enterprise plan).
PROXYSCRAPE_RESI_ENDPOINT=             # host:port (e.g. rp.proxyscrape.com:6060)
PROXYSCRAPE_RESI_USERNAME=
PROXYSCRAPE_RESI_PASSWORD=
# Camoufox (L4 — last resort, Firefox fork; ~300-500MB binary via `npx camoufox-js fetch`).
CAMOUFOX_HEADLESS=true
CAMOUFOX_TIMEOUT_MS=60000
# Cascade kill-switches (set to "false" to skip a level): L2 / L3 / L4 respectively.
SCRAPING_LEVEL_1_ENABLED=true
SCRAPING_LEVEL_2_ENABLED=true
SCRAPING_LEVEL_3_ENABLED=true
# Navigation wait strategy (F6). Default: domcontentloaded + a bounded settle —
# `networkidle` hangs the full timeout on analytics/polling pages. Kill-switch:
# set SCRAPE_WAIT_NETWORKIDLE=true to restore the legacy networkidle behavior.
SCRAPE_WAIT_NETWORKIDLE=false
SCRAPE_SETTLE_MS=2500                   # max ms to let late XHR/hydration settle after domcontentloaded
# Default cadence (days) for re-scanning the user's own product site (patch-12).
USER_PRODUCT_RESCAN_DAYS=14

# Homepage scraping v2 (patch-16) — homepage monitors only
HOMEPAGE_SCROLL_PASSES=2                # progressive scroll passes (reveal lazy content)
HOMEPAGE_LAZY_WAIT_MS=2000              # wait after each scroll pass for lazy loads
HOMEPAGE_NARRATIVE_MIN_SEVERITY=medium # min severity to generate a narrative (none|low|medium|high|critical)

# Homepage enrichments (patch-17) — homepage monitors only
ENRICHMENTS_PHASH_THRESHOLD=15          # Hamming distance above which a visual redesign is flagged
ENRICHMENTS_VOLATILE_THRESHOLD=5        # consecutive scrapes a line must differ to be marked volatile
ENRICHMENTS_VOLATILE_RESET=10           # consecutive stable scrapes for a volatile line to become analysable again
ENRICHMENTS_ANTIVOID_THRESHOLD=0.3      # content-size ratio vs the median of the last 5 snapshots
ENRICHMENTS_RELEVANCE_MIN_SCORE=0.5     # minimum relevance score for a change to generate a signal

# Tech stack detection (patch-18) — independent monthly scraper, no third-party API
TECH_STACK_SCRAPE_INTERVAL_DAYS=30      # days between tech-stack scrapes per competitor
TECH_STACK_SIGNAL_MIN_IMPORTANCE=medium # min tech importance to emit a signal on appearance (low|medium|high)

# Staged extraction pipeline (patch-30) — structured-first → cached parser →
# validation → AI self-heal. AI moves off the hot path (every scrape) onto the
# cold path (extractor creation + rare repairs). Kill-switch off → exact current
# behaviour (direct AI extraction, the ai_fallback floor).
STAGED_EXTRACTION_ENABLED=true     # false → bypass all new stages, behave as today
EXTRACTOR_HEAL_COOLDOWN_HOURS=12   # min hours between self-heal attempts on a broken extractor (anti-thrash)
PRUNE_HTML_MAX_CHARS=40000         # cap of the pruned HTML sent to the selector generator

# Platform auto-detection (patch-31) — pure, AI-free detection of each competitor's
# stack (framework/cms/ats/pricingWidget/statusPage/changelog/analytics) + extracted
# identifiers, cached on competitors.platform_profile to route sources to structured
# connectors. Kill-switch off → no profile written, routing = exactly today.
PLATFORM_DETECTION_ENABLED=true    # false → no detection, no profile, routing unchanged
PLATFORM_REDETECT_INTERVAL_DAYS=30 # periodic re-detection cadence per competitor
PLATFORM_DNS_ENABLED=true          # resolve CNAME (signal 6, node:dns); false → skip it
PLATFORM_STEP_B_ENABLED=true       # allow the browser api-capture fallback when step A is thin
PLATFORM_REDETECT_DRIFT_COOLDOWN_HOURS=24  # min hours between drift-triggered re-detections (self-heal)

# Edge cases scraping (patch-23) — pivot/death detection + SPA api capture
PIVOT_DETECTION_MIN_SCRAPES=3            # consecutive snapshots required before confirming a structural change
PIVOT_DETECTION_TEXT_DIFF_THRESHOLD=0.8 # fraction of text that must differ (0-1) to flag a pivot
PIVOT_DETECTION_PHASH_DISTANCE=20       # Hamming distance above which the visual is considered a full redesign
SPA_DETECTION_HTML_MIN_TEXT_LENGTH=500  # below this many chars of visible text, a 200 is a likely pure SPA
SPA_API_CAPTURE_TIMEOUT_MS=15000        # how long to observe XHR/fetch calls when capturing a SPA's API

# Discovery
EXA_API_KEY=

# Onboarding latency & background processing (patch-25)
NEXT_PUBLIC_ONBOARDING_PARALLEL_DISCOVERY=true   # prefetch discovery while editing the profile ("false" disables)
NEXT_PUBLIC_ONBOARDING_DISCOVERY_DEBOUNCE_MS=3000 # debounce before the background prefetch (limits Exa spend on edits)
ONBOARDING_RESUME_TTL_DAYS=7                      # how long an unfinished onboarding session stays resumable

# Sectoral intelligence (Patch 13) — meso-level trends across an org's own competitors
SECTORAL_ANALYSIS_DAY=monday      # documented only; the Trigger.dev cron is static (Mon 07:00 UTC)
SECTORAL_MIN_COMPETITORS=4        # min active competitors before an org is analyzed
SECTORAL_MIN_CONFIDENCE=0.6       # min pattern confidence (0-1) required to publish a signal

# Upstash Redis — AI cache backend (Patch 09) AND the hard rate limiters
# (anti-OTP-brute-force + anti-AI-abuse). Optional in dev/test (empty → cache and
# rate limiting both no-op). REQUIRED in production: the API fails to boot without
# these when NODE_ENV=production, so rate limiting is never silently disabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI
ANTHROPIC_API_KEY=
GROQ_API_KEY=             # back-compat: synthesizes a Groq provider if no AI_PROVIDER_N set

# AI provider pool (Patch 22). Legal pool of OpenAI-compatible providers, tried
# free-first then paid. priority = try order (lower first). Numbered contiguously
# AI_PROVIDER_1..N (stops at first gap). dailyTokenQuota is total tokens/day; the
# pool skips a provider at 95% of it. Empty → falls back to GROQ_API_KEY above.
# NOTE: do NOT run multiple Groq accounts (violates Groq ToS) — use distinct providers.
AI_PROVIDER_1_ID=cerebras
AI_PROVIDER_1_BASE_URL=https://api.cerebras.ai/v1
AI_PROVIDER_1_API_KEY=
AI_PROVIDER_1_MODEL=llama-3.3-70b
# Optional cheap small (8B-class) model on the SAME endpoint. "fast"-tier tasks
# (classify-change, overlap scoring) route here — ~10× cheaper than the 70B.
# Omit to keep every task on _MODEL (today's behavior).
AI_PROVIDER_1_FAST_MODEL=llama-3.1-8b
AI_PROVIDER_1_TIER=free
AI_PROVIDER_1_DAILY_TOKEN_QUOTA=1000000
AI_PROVIDER_1_PRIORITY=1
# Optional, reasoning models only (gpt-oss): low|medium|high. Omit → callLLM auto-
# picks "low" for gpt-oss models (validated cheapest, equal quality) and sends
# nothing for non-reasoning models like Llama. Set only to deviate from "low".
# AI_PROVIDER_1_REASONING_EFFORT=low

AI_PROVIDER_2_ID=groq
AI_PROVIDER_2_BASE_URL=https://api.groq.com/openai/v1
AI_PROVIDER_2_API_KEY=
# gpt-oss-120b on Groq: ~4× cheaper input, smarter, cacheable, and validated equal
# quality + JSON adherence vs llama-3.3-70b (src/eval/model-eval.ts). reasoning_effort
# auto-pins to "low". Each provider has its OWN model id (Groq: openai/gpt-oss-120b;
# Cerebras: gpt-oss-120b) — validate per provider before flipping it.
AI_PROVIDER_2_MODEL=openai/gpt-oss-120b
AI_PROVIDER_2_FAST_MODEL=llama-3.1-8b-instant
AI_PROVIDER_2_TIER=free
AI_PROVIDER_2_DAILY_TOKEN_QUOTA=500000
AI_PROVIDER_2_PRIORITY=2

AI_PROVIDER_3_ID=hyperbolic
AI_PROVIDER_3_BASE_URL=https://api.hyperbolic.xyz/v1
AI_PROVIDER_3_API_KEY=
AI_PROVIDER_3_MODEL=meta-llama/Llama-3.3-70B-Instruct
AI_PROVIDER_3_TIER=paid
AI_PROVIDER_3_DAILY_TOKEN_QUOTA=100000000
AI_PROVIDER_3_PRIORITY=3

# Circuit breaker (Patch 22) — global trip after N consecutive failures across all providers.
AI_CIRCUIT_BREAKER_THRESHOLD=5
AI_CIRCUIT_BREAKER_RESET_MIN=10

# Hard anti-abuse rate limit (Patch 22) — AI-intensive actions per user per window.
AI_INTENSIVE_RATE_LIMIT=10
AI_INTENSIVE_WINDOW_SEC=3600

# AI cache TTLs in days (Patch 09 — deterministic tasks only)
AI_CACHE_TTL_CLASSIFY_DAYS=7
AI_CACHE_TTL_ANALYZE_DAYS=30
AI_CACHE_TTL_SCORE_DAYS=30

# Anti-hallucination (Patch 24 — grounding + self-check + transparency)
GROUNDING_VALIDATION_ENABLED=true          # validate AI citations against the source text
GROUNDING_FUZZY_MATCH_THRESHOLD=0.85       # fuzzy-match threshold for a citation to count as grounded
SELF_CHECK_BATTLE_CARDS=true               # always run a 2nd-pass self-check on battle cards
SELF_CHECK_SAMPLING_RATE=0                 # fraction of other outputs sampled for a self-check (0 = off; battle cards + low-confidence still checked)
CONFIDENCE_DOT_THRESHOLD=high              # show the ConfidenceDot only when confidence < this (high|medium)
AI_HALLUCINATION_ALERT_RATE=0.03           # Slack ops alert if a task's hallucination rate exceeds this over 7d
# Mirrored to the web bundle for the ConfidenceDot visibility rule + ops metric highlight:
NEXT_PUBLIC_CONFIDENCE_DOT_THRESHOLD=high
NEXT_PUBLIC_AI_HALLUCINATION_ALERT_RATE=0.03

# Email
RESEND_API_KEY=

# Notification moderation (patch-26)
NOTIFICATION_DAILY_EMAIL_CAP=10      # max immediate emails/day per org (critical bypasses)
NOTIFICATION_CRITICAL_BYPASS=true    # critical severity ignores every filter
QUIET_HOURS_DEFAULT_START=22         # default quiet-hours start, 0-23 org-local
QUIET_HOURS_DEFAULT_END=8            # default quiet-hours end, 0-23 org-local
QUIET_HOURS_WEEKEND_OFF=true         # mute Sat+Sun by default
RELEVANCE_THRESHOLD_DEFAULT=0.5      # default per-org relevance threshold (0-1)
RELEVANCE_AUTO_ADJUST_MIN_FEEDBACKS=10 # min org feedbacks before auto-adjusting the threshold
RELEVANCE_RECALC_INTERVAL_HOURS=168  # threshold recalc cadence (weekly = 7*24)
BATCHING_WINDOW_HOURS=24             # window for grouping similar signals
BATCHING_MIN_SIGNALS=3               # min similar signals to form a batch

# Stale-data actions (patch-27)
# Per-source-type freshness thresholds "yellow,orange,red" in days. Server-side
# only (the web dot uses these defaults). Categories: github_repo→features.
STALENESS_THRESHOLDS_PRICING=7,14,30
STALENESS_THRESHOLDS_FEATURES=14,30,60
STALENESS_THRESHOLDS_REVIEWS=21,45,90
STALENESS_THRESHOLDS_JOBS=14,30,60
STALENESS_THRESHOLDS_BLOG=30,60,120
STALENESS_THRESHOLDS_HOMEPAGE=14,30,60
# User-forced re-scan daily limit per tier (counted per user). Optional override of
# PLAN_LIMITS defaults (tier-limits 2026-06-04: business is a real 100 cap, not unlimited).
FORCED_RESCAN_LIMIT_FREE=1
FORCED_RESCAN_LIMIT_STARTER=5
FORCED_RESCAN_LIMIT_PRO=20
FORCED_RESCAN_LIMIT_BUSINESS=100
# Ops + user alert when an active monitor has produced no signal for this long.
SILENT_MONITOR_ALERT_THRESHOLD_DAYS=60

# Self-product multi-SKU (patch-28)
# Max active products (SKUs) per org by plan tier. One product = the classic
# single self-product flow (transparent for mono-product users).
PRODUCT_LIMIT_FREE=1
PRODUCT_LIMIT_STARTER=2
PRODUCT_LIMIT_PRO=5
PRODUCT_LIMIT_BUSINESS=999

# Payments (Stripe — Phase 7)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_YEARLY=

# Frontend
NEXT_PUBLIC_API_URL=       # https://api.outrival.io
WEB_URL=                   # https://outrival.io — used by Stripe success/cancel URLs

# Observability (Patch 04)
LOG_LEVEL=info             # debug | info | warn | error
SENTRY_DSN_API=
SENTRY_DSN_WORKERS=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_DSN=    # mirror of SENTRY_DSN_WEB (exposed to the browser)
SENTRY_AUTH_TOKEN=         # source maps upload (build-time)
SENTRY_ORG=
SENTRY_PROJECT_WEB=outrival-web
# Optional log shipping (deferred)
AXIOM_TOKEN=
AXIOM_DATASET=outrival

# Analytics (Patch 03 — PostHog Cloud EU)
NEXT_PUBLIC_POSTHOG_KEY=        # phc_... (project API key, same as POSTHOG_API_KEY)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=                # phc_... (server-side, same project key)
POSTHOG_HOST=https://eu.i.posthog.com

# Feedback widget (Patch 05) — Slack webhook ops (perso, distinct des webhooks org)
OPS_SLACK_WEBHOOK_URL=

# Admin ops (Patch 02) — comma-separated allowlist of operator emails. Gates the
# /admin dashboard and /api/admin/* routes. NOT the org "owner" role.
ADMIN_EMAILS=

# Quality feedback loop (Patch 21) — both optional, sensible defaults shown.
FEEDBACK_NPS_INTERVAL_DAYS=30    # min days between NPS prompts for the same user
FEEDBACK_AGGREGATE_MIN_COUNT=5   # min feedbacks before a pattern is surfaced in /admin
