{
  "name": "@outrival/db",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 20000 test/",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:deploy": "bun run src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:baseline": "bun run src/baseline.ts",
    "db:backfill-news": "bun run src/backfill-news-monitors.ts"
  },
  "dependencies": {
    "@outrival/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10"
  }
}
